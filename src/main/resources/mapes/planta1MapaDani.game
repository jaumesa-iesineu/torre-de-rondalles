        <habitacio id="centre_3"
                    x="25"
                    y="30"
                    amplada="20"
                    alcada="6"
                    porta="2"
                    portaEsp="1">
            <descripcio>Zona central inferior.</descripcio>
        </habitacio>

        <!-- DRETA -->
        <habitacio id="dreta_1"
                    x="55"
                    y="3"
                    amplada="18"
                    alcada="8"
                    porta="2"
                    portaEsp="1">
            <descripcio>Zona dreta superior.</descripcio>
