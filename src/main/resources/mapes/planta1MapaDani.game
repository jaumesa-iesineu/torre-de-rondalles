<?xml version="1.0" encoding="UTF-8"?>

<mapa id="mapa_gran_ascii" nom="Mapa ASCII Gran">

    <habitacions>

        <!-- EXTERIOR -->
        <habitacio id="exterior"
                    x="0"
                    y="0"
                    amplada="120"
                    alcada="40"
                    porta="1"
                    portaEsp="1">
            <descripcio>Exterior del mapa.</descripcio>
        </habitacio>

        <!-- COLUMNA ESQUERRA -->
        <habitacio id="esq_1"
                    x="2"
                    y="4"
