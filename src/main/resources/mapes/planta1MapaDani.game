    </habitacions>

    <connexions>

        <!-- ESQUERRA -->
        <connexio de="esq_1" a="esq_2" direccio="sud"/>
        <connexio de="esq_2" a="esq_3" direccio="sud"/>

        <!-- CENTRE -->
        <connexio de="centre_1" a="centre_2" direccio="sud"/>
        <connexio de="centre_2" a="centre_3" direccio="sud"/>

        <!-- DRETA -->
        <connexio de="dreta_1" a="dreta_2" direccio="sud"/>
        <connexio de="dreta_2" a="dreta_3" direccio="sud"/>

        <!-- EXTREM -->
        <connexio de="extrem_1" a="extrem_2" direccio="sud"/>
        <connexio de="extrem_2" a="extrem_3" direccio="sud"/>

        <!-- HORITZONTALS SUPERIOR -->
        <connexio de="esq_1" a="passadis_1" direccio="est"/>
        <connexio de="passadis_1" a="centre_1" direccio="est"/>

        <connexio de="centre_1" a="passadis_2" direccio="est"/>
        <connexio de="passadis_2" a="dreta_1" direccio="est"/>

        <connexio de="dreta_1" a="passadis_3" direccio="est"/>
        <connexio de="passadis_3" a="extrem_1" direccio="est"/>

        <!-- HORITZONTALS CENTRE -->
        <connexio de="esq_2" a="passadis_4" direccio="est"/>
        <connexio de="passadis_4" a="centre_2" direccio="est"/>

        <connexio de="centre_2" a="passadis_5" direccio="est"/>
        <connexio de="passadis_5" a="dreta_2" direccio="est"/>

        <connexio de="dreta_2" a="passadis_6" direccio="est"/>
        <connexio de="passadis_6" a="extrem_2" direccio="est"/>

    </connexions>

</mapa>